rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---------------------------------------------------------------
    // Any signed-in user may *read* /users/{uid} so that group members can look
    // each other up by email when sending invites. Only the owning user can
    // write their own profile and ad-hoc subtree.
    match /users/{uid} {
      allow get: if request.auth != null;
      allow list: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      // Per-user ad-hoc ledger is strictly private to the owner.
      // Friends: the owner has full access. Additionally, any other signed-in
      // user may add OR remove themselves as a reciprocal friend, but only via
      // a doc keyed by their own uid that links back to themselves. This keeps
      // friendships mutual without letting anyone write arbitrary friend rows.
      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null
          && request.auth.uid != uid
          && friendId == request.auth.uid
          && request.resource.data.linkedUid == request.auth.uid
          && request.resource.data.id == request.auth.uid;
        allow delete: if request.auth != null
          && request.auth.uid != uid
          && friendId == request.auth.uid;
      }
      match /adhocExpenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /adhocPayments/{paymentId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Group invites: the owning user reads/deletes their own. Other signed-in
      // users may *create* an invite for someone they want to invite (the
      // create rule guarantees they're already a member of the referenced
      // group, so they can't spam strangers with arbitrary group ids).
      match /groupInvites/{inviteId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
          && request.auth.uid != uid
          && request.resource.data.invitedByUid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberUids;
        allow update: if request.auth != null && request.auth.uid == uid;
      }
    }

    // --- Groups (multi-user shared) -----------------------------------------
    match /groups/{groupId} {
      // Read: any current member.
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      // Create: caller must include themselves in memberUids so they pass the
      // read rule on their own freshly-created group.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.createdBy == request.auth.uid;

      // Update: existing members may edit metadata. The only legal change to
      // memberUids is appending the caller's own uid (i.e. accepting an
      // invite), or a current member appending nothing (a no-op).
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberUids
        && (
          request.resource.data.memberUids == resource.data.memberUids
          || request.resource.data.memberUids.toSet().difference(resource.data.memberUids.toSet()) == [request.auth.uid].toSet()
        );

      // Delete: original creator only.
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      // Subcollections are accessible to every member of the parent group.
      match /{subcollection=**}/{docId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
        allow write: if request.auth != null
          && request.auth.uid in getAfter(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
      }
    }
  }
}
