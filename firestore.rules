rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ------------------------------------------------------------
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isString(value, max) {
      return value is string && value.size() <= max;
    }

    function isNonEmptyString(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function isOptionalEmail(value) {
      return value is string && value.size() <= 254;
    }

    function isMoney(value) {
      return value is number && value > 0 && value <= 100000000;
    }

    function isMillis(value) {
      return value is number && value >= 0 && value <= 4102444800000;
    }

    function isCurrency(value) {
      return value in ["USD", "EUR", "GBP", "INR", "JPY", "CAD", "AUD"];
    }

    function isSplitType(value) {
      return value in ["EQUAL", "EXACT"];
    }

    function isSmallStringMap(value) {
      return value is map && value.keys().size() > 0 && value.keys().size() <= 100;
    }

    function isUserDoc(uid) {
      return request.resource.data.keys().hasOnly([
          "uid", "displayName", "email", "photoUrl", "updatedAt"
        ])
        && request.resource.data.keys().hasAll(["uid", "displayName", "email"])
        && request.resource.data.uid == uid
        && isNonEmptyString(request.resource.data.displayName, 80)
        && isOptionalEmail(request.resource.data.email)
        && isString(request.resource.data.photoUrl, 500)
        && (
          !("updatedAt" in request.resource.data)
          || request.resource.data.updatedAt is timestamp
          || isMillis(request.resource.data.updatedAt)
        );
    }

    function groupExists(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId));
    }

    function groupMember(groupId) {
      return signedIn()
        && groupExists(groupId)
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    function groupMemberAfter(groupId) {
      return signedIn()
        && request.auth.uid in getAfter(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    function groupCreator(groupId) {
      return signedIn()
        && groupExists(groupId)
        && get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy == request.auth.uid;
    }

    function groupCreatorAfter(groupId) {
      return signedIn()
        && getAfter(/databases/$(database)/documents/groups/$(groupId)).data.createdBy == request.auth.uid;
    }

    function hasInviteFor(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/groupInvites/$(groupId));
    }

    function isGroupDoc(groupId) {
      return request.resource.data.keys().hasOnly([
          "id", "name", "description", "createdAt", "createdBy", "memberUids"
        ])
        && request.resource.data.keys().hasAll([
          "id", "name", "description", "createdAt", "createdBy", "memberUids"
        ])
        && request.resource.data.id == groupId
        && isNonEmptyString(request.resource.data.name, 100)
        && isString(request.resource.data.description, 500)
        && isMillis(request.resource.data.createdAt)
        && isNonEmptyString(request.resource.data.createdBy, 128)
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() > 0
        && request.resource.data.memberUids.size() <= 100;
    }

    function groupImmutableFieldsUnchanged() {
      return request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy;
    }

    function isMetadataOnlyGroupUpdate(groupId) {
      return groupMember(groupId)
        && isGroupDoc(groupId)
        && groupImmutableFieldsUnchanged()
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["name", "description"]);
    }

    function isInviteAcceptance(groupId) {
      return signedIn()
        && !groupMember(groupId)
        && hasInviteFor(groupId)
        && isGroupDoc(groupId)
        && groupImmutableFieldsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberUids"])
        && request.resource.data.memberUids.toSet().difference(resource.data.memberUids.toSet()) == [request.auth.uid].toSet()
        && resource.data.memberUids.toSet().difference(request.resource.data.memberUids.toSet()) == [].toSet();
    }

    function isMemberDoc(groupId, memberId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "name", "email", "linkedUid"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "name", "email", "linkedUid"
        ])
        && request.resource.data.id == memberId
        && request.resource.data.groupId == groupId
        && isNonEmptyString(request.resource.data.name, 80)
        && isOptionalEmail(request.resource.data.email)
        && isString(request.resource.data.linkedUid, 128)
        && (
          request.resource.data.linkedUid == ""
          || request.resource.data.linkedUid in getAfter(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
        );
    }

    function isGroupMemberCreate(groupId, memberId) {
      return groupMemberAfter(groupId)
        && isMemberDoc(groupId, memberId)
        && (
          groupCreatorAfter(groupId)
          || request.resource.data.linkedUid == request.auth.uid
        );
    }

    function memberExists(groupId, memberId) {
      return memberId is string
        && memberId.size() > 0
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(memberId));
    }

    function isExpenseDoc(groupId, expenseId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "description", "amount", "paidById", "splitType",
          "timestamp", "currency", "splits"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "description", "amount", "paidById", "splitType",
          "timestamp", "currency", "splits"
        ])
        && request.resource.data.id == expenseId
        && request.resource.data.groupId == groupId
        && isNonEmptyString(request.resource.data.description, 160)
        && isMoney(request.resource.data.amount)
        && memberExists(groupId, request.resource.data.paidById)
        && isSplitType(request.resource.data.splitType)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency)
        && isSmallStringMap(request.resource.data.splits);
    }

    function isPaymentDoc(groupId, paymentId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "fromMemberId", "toMemberId", "amount",
          "timestamp", "currency"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "fromMemberId", "toMemberId", "amount",
          "timestamp", "currency"
        ])
        && request.resource.data.id == paymentId
        && request.resource.data.groupId == groupId
        && request.resource.data.fromMemberId != request.resource.data.toMemberId
        && memberExists(groupId, request.resource.data.fromMemberId)
        && memberExists(groupId, request.resource.data.toMemberId)
        && isMoney(request.resource.data.amount)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency);
    }

    function isFriendDoc(friendId) {
      return request.resource.data.keys().hasOnly([
          "id", "name", "email", "phone", "createdAt", "linkedUid"
        ])
        && request.resource.data.keys().hasAll([
          "id", "name", "email", "phone", "createdAt", "linkedUid"
        ])
        && request.resource.data.id == friendId
        && isNonEmptyString(request.resource.data.name, 80)
        && isOptionalEmail(request.resource.data.email)
        && isString(request.resource.data.phone, 40)
        && isMillis(request.resource.data.createdAt)
        && isString(request.resource.data.linkedUid, 128);
    }

    function selfOrFriend(uid, participantId) {
      return participantId == "self"
        || exists(/databases/$(database)/documents/users/$(uid)/friends/$(participantId));
    }

    function isAdHocExpenseDoc(uid, expenseId) {
      return request.resource.data.keys().hasOnly([
          "id", "description", "amount", "paidByFriendId", "splitType",
          "timestamp", "currency", "splits"
        ])
        && request.resource.data.keys().hasAll([
          "id", "description", "amount", "paidByFriendId", "splitType",
          "timestamp", "currency", "splits"
        ])
        && request.resource.data.id == expenseId
        && isNonEmptyString(request.resource.data.description, 160)
        && isMoney(request.resource.data.amount)
        && selfOrFriend(uid, request.resource.data.paidByFriendId)
        && isSplitType(request.resource.data.splitType)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency)
        && isSmallStringMap(request.resource.data.splits);
    }

    function isAdHocPaymentDoc(uid, paymentId) {
      return request.resource.data.keys().hasOnly([
          "id", "fromFriendId", "toFriendId", "amount", "timestamp", "currency"
        ])
        && request.resource.data.keys().hasAll([
          "id", "fromFriendId", "toFriendId", "amount", "timestamp", "currency"
        ])
        && request.resource.data.id == paymentId
        && request.resource.data.fromFriendId != request.resource.data.toFriendId
        && selfOrFriend(uid, request.resource.data.fromFriendId)
        && selfOrFriend(uid, request.resource.data.toFriendId)
        && isMoney(request.resource.data.amount)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency);
    }

    function isInviteDoc(inviteId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "groupName", "invitedByUid", "invitedByName", "invitedAt"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "groupName", "invitedByUid", "invitedByName", "invitedAt"
        ])
        && request.resource.data.id == inviteId
        && request.resource.data.groupId == inviteId
        && request.resource.data.invitedByUid == request.auth.uid
        && isNonEmptyString(request.resource.data.groupName, 100)
        && isNonEmptyString(request.resource.data.invitedByName, 80)
        && isMillis(request.resource.data.invitedAt);
    }

    // --- Users ---------------------------------------------------------------
    match /users/{uid} {
      // The app currently searches users by email for friend/group invite flows,
      // so reads remain signed-in. Writes are owner-only and schema-checked.
      allow get, list: if signedIn();
      allow create, update: if isOwner(uid) && isUserDoc(uid);
      allow delete: if false;

      match /friends/{friendId} {
        allow read: if isOwner(uid);
        allow create, update: if (
          isOwner(uid)
          || (
            signedIn()
            && request.auth.uid != uid
            && friendId == request.auth.uid
            && request.resource.data.linkedUid == request.auth.uid
          )
        ) && isFriendDoc(friendId);
        allow delete: if isOwner(uid)
          || (
            signedIn()
            && request.auth.uid != uid
            && friendId == request.auth.uid
          );
      }

      match /adhocExpenses/{expenseId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isAdHocExpenseDoc(uid, expenseId);
        allow delete: if isOwner(uid);
      }

      match /adhocPayments/{paymentId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isAdHocPaymentDoc(uid, paymentId);
        allow delete: if isOwner(uid);
      }

      match /groupInvites/{inviteId} {
        allow read, delete: if isOwner(uid);
        allow create: if signedIn()
          && request.auth.uid != uid
          && isInviteDoc(inviteId)
          && groupMember(request.resource.data.groupId);
        allow update: if false;
      }
    }

    // --- Groups --------------------------------------------------------------
    match /groups/{groupId} {
      allow read: if groupMember(groupId);

      allow create: if signedIn()
        && isGroupDoc(groupId)
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      allow update: if isMetadataOnlyGroupUpdate(groupId)
        || isInviteAcceptance(groupId);

      allow delete: if groupCreator(groupId);

      match /members/{memberId} {
        allow read: if groupMember(groupId);
        allow create: if isGroupMemberCreate(groupId, memberId);
        allow update: if false;
        allow delete: if groupCreator(groupId);
      }

      match /expenses/{expenseId} {
        allow read: if groupMember(groupId);
        allow create, update: if groupMember(groupId)
          && isExpenseDoc(groupId, expenseId);
        allow delete: if groupMember(groupId);
      }

      match /payments/{paymentId} {
        allow read: if groupMember(groupId);
        allow create, update: if groupMember(groupId)
          && isPaymentDoc(groupId, paymentId);
        allow delete: if groupMember(groupId);
      }
    }
  }
}
