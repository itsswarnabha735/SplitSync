rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ------------------------------------------------------------
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isString(value, max) {
      return value is string && value.size() <= max;
    }

    function isNonEmptyString(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function isOptionalEmail(value) {
      return value is string && value.size() <= 254;
    }

    function isMoney(value) {
      return value is number && value > 0 && value <= 100000000;
    }

    function isMillis(value) {
      return value is number && value >= 0 && value <= 4102444800000;
    }

    function isNullableMillis(value) {
      return value == null || isMillis(value);
    }

    function isCurrency(value) {
      return value in ["USD", "EUR", "GBP", "INR", "JPY", "CAD", "AUD"];
    }

    function isActorUid(value) {
      return value is string && value == request.auth.uid;
    }

    function isSplitType(value) {
      return value in ["EQUAL", "EXACT"];
    }

    function isGroupStatus(value) {
      return value in ["active", "archived"];
    }

    function isGroupTemplate(value) {
      return value in ["custom", "trip", "flatmates", "couple", "office", "event"];
    }

    function isPaymentMethod(value) {
      return value in ["upi", "bank", "cash", "other"];
    }

    function isRecurringFrequency(value) {
      return value in ["weekly", "monthly", "quarterly", "yearly"];
    }

    function isExpenseDisputeStatus(value) {
      return value in ["none", "needs_clarification", "resolved"];
    }

    function isSettlementRequestStatus(value) {
      return value in ["requested", "reminded", "dismissed", "settled"];
    }

    function isExpenseCategory(value) {
      return value in [
        "food-dining", "groceries", "transport", "fuel", "shopping",
        "entertainment", "utilities", "travel", "health", "housing",
        "investments", "fees", "income", "transfers", "other"
      ];
    }

    function isExpenseSourceType(value) {
      return value in [
        "statement-import", "ai-text", "pasted-message", "receipt-image", "manual"
      ];
    }

    function isStatementParserMode(value) {
      return value in ["ai-assisted", "local-only"];
    }

    function hasValidExpenseImportProvenance() {
      return (
          !("sourceType" in request.resource.data)
          || isExpenseSourceType(request.resource.data.sourceType)
        )
        && (
          !("importBatchId" in request.resource.data)
          || isNonEmptyString(request.resource.data.importBatchId, 80)
        )
        && (
          !("transactionFingerprint" in request.resource.data)
          || isNonEmptyString(request.resource.data.transactionFingerprint, 160)
        )
        && (
          !("parserMode" in request.resource.data)
          || isStatementParserMode(request.resource.data.parserMode)
        )
        && (
          !("parserConfidence" in request.resource.data)
          || (
            request.resource.data.parserConfidence is number
            && request.resource.data.parserConfidence >= 0
            && request.resource.data.parserConfidence <= 1
          )
        );
    }

    function isOptionalStringList(value, maxItems) {
      return value is list && value.size() <= maxItems;
    }

    function isOptionalRatio(value) {
      return value is number && value >= 0 && value <= 1;
    }

    function isCreatorFieldValid() {
      return !("createdByUid" in request.resource.data)
        || isActorUid(request.resource.data.createdByUid)
        || (
          "createdByUid" in resource.data
          && request.resource.data.createdByUid == resource.data.createdByUid
        );
    }

    function hasValidExpenseMetadata() {
      return (
          !("notes" in request.resource.data)
          || isString(request.resource.data.notes, 500)
        )
        && (
          !("sourceConfidence" in request.resource.data)
          || isOptionalRatio(request.resource.data.sourceConfidence)
        )
        && (
          !("sourceWarnings" in request.resource.data)
          || isOptionalStringList(request.resource.data.sourceWarnings, 10)
        )
        && (
          !("createdAt" in request.resource.data)
          || isMillis(request.resource.data.createdAt)
        )
        && (
          !("updatedAt" in request.resource.data)
          || isMillis(request.resource.data.updatedAt)
        )
        && (
          !("lastEditedByUid" in request.resource.data)
          || isActorUid(request.resource.data.lastEditedByUid)
        )
        && (
          !("editCount" in request.resource.data)
          || (
            request.resource.data.editCount is number
            && request.resource.data.editCount >= 0
            && request.resource.data.editCount <= 100000
          )
        );
    }

    function hasValidExpenseFxMetadata() {
      return (
          !("originalAmount" in request.resource.data)
          || isMoney(request.resource.data.originalAmount)
        )
        && (
          !("originalCurrency" in request.resource.data)
          || isCurrency(request.resource.data.originalCurrency)
        )
        && (
          !("exchangeRate" in request.resource.data)
          || (
            request.resource.data.exchangeRate is number
            && request.resource.data.exchangeRate > 0
            && request.resource.data.exchangeRate <= 1000000
          )
        )
        && (
          !("fxNote" in request.resource.data)
          || isString(request.resource.data.fxNote, 300)
        );
    }

    function hasValidExpenseDisputeMetadata() {
      return (
          !("disputeStatus" in request.resource.data)
          || isExpenseDisputeStatus(request.resource.data.disputeStatus)
        )
        && (
          !("disputedByUid" in request.resource.data)
          || isActorUid(request.resource.data.disputedByUid)
          || (
            "disputedByUid" in resource.data
            && request.resource.data.disputedByUid == resource.data.disputedByUid
          )
        )
        && (
          !("disputedAt" in request.resource.data)
          || isMillis(request.resource.data.disputedAt)
        )
        && (
          !("disputeNote" in request.resource.data)
          || isString(request.resource.data.disputeNote, 500)
        );
    }

    function isSmallStringMap(value) {
      return value is map && value.keys().size() > 0 && value.keys().size() <= 100;
    }

    function isUserDoc(uid) {
      return request.resource.data.keys().hasOnly([
          "uid", "displayName", "email", "photoUrl", "updatedAt"
        ])
        && request.resource.data.keys().hasAll(["uid", "displayName", "email"])
        && request.resource.data.uid == uid
        && isNonEmptyString(request.resource.data.displayName, 80)
        && isOptionalEmail(request.resource.data.email)
        && isString(request.resource.data.photoUrl, 500)
        && (
          !("updatedAt" in request.resource.data)
          || request.resource.data.updatedAt is timestamp
          || isMillis(request.resource.data.updatedAt)
        );
    }

    function groupExists(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId));
    }

    function groupMember(groupId) {
      return signedIn()
        && groupExists(groupId)
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    function groupMemberAfter(groupId) {
      return signedIn()
        && request.auth.uid in getAfter(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    function groupCreator(groupId) {
      return signedIn()
        && groupExists(groupId)
        && get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy == request.auth.uid;
    }

    function groupCreatorAfter(groupId) {
      return signedIn()
        && getAfter(/databases/$(database)/documents/groups/$(groupId)).data.createdBy == request.auth.uid;
    }

    function hasInviteFor(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/groupInvites/$(groupId));
    }

    function isGroupDoc(groupId) {
      return request.resource.data.keys().hasOnly([
          "id", "name", "description", "createdAt", "createdBy", "memberUids",
          "status", "archivedAt", "archivedByUid", "template",
          "defaultCurrency", "settlementCurrency", "travelMode"
        ])
        && request.resource.data.keys().hasAll([
          "id", "name", "description", "createdAt", "createdBy", "memberUids"
        ])
        && request.resource.data.id == groupId
        && isNonEmptyString(request.resource.data.name, 100)
        && isString(request.resource.data.description, 500)
        && isMillis(request.resource.data.createdAt)
        && isNonEmptyString(request.resource.data.createdBy, 128)
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() > 0
        && request.resource.data.memberUids.size() <= 100
        && (
          !("status" in request.resource.data)
          || isGroupStatus(request.resource.data.status)
        )
        && (
          !("archivedAt" in request.resource.data)
          || isMillis(request.resource.data.archivedAt)
        )
        && (
          !("archivedByUid" in request.resource.data)
          || isString(request.resource.data.archivedByUid, 128)
        )
        && (
          !("template" in request.resource.data)
          || isGroupTemplate(request.resource.data.template)
        )
        && (
          !("defaultCurrency" in request.resource.data)
          || isCurrency(request.resource.data.defaultCurrency)
        )
        && (
          !("settlementCurrency" in request.resource.data)
          || isCurrency(request.resource.data.settlementCurrency)
        )
        && (
          !("travelMode" in request.resource.data)
          || request.resource.data.travelMode is bool
        );
    }

    function groupImmutableFieldsUnchanged() {
      return request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy;
    }

    function isMetadataOnlyGroupUpdate(groupId) {
      return groupMember(groupId)
        && isGroupDoc(groupId)
        && groupImmutableFieldsUnchanged()
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name", "description", "status", "archivedAt", "archivedByUid",
          "template", "defaultCurrency", "settlementCurrency", "travelMode"
        ]);
    }

    function isInviteAcceptance(groupId) {
      return signedIn()
        && !groupMember(groupId)
        && hasInviteFor(groupId)
        && isGroupDoc(groupId)
        && groupImmutableFieldsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberUids"])
        && request.resource.data.memberUids.toSet().difference(resource.data.memberUids.toSet()) == [request.auth.uid].toSet()
        && resource.data.memberUids.toSet().difference(request.resource.data.memberUids.toSet()) == [].toSet();
    }

    function isMemberDoc(groupId, memberId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "name", "email", "linkedUid",
          "preferredPaymentMethod", "paymentHandle", "paymentLink"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "name", "email", "linkedUid"
        ])
        && request.resource.data.id == memberId
        && request.resource.data.groupId == groupId
        && isNonEmptyString(request.resource.data.name, 80)
        && isOptionalEmail(request.resource.data.email)
        && isString(request.resource.data.linkedUid, 128)
        && (
          request.resource.data.linkedUid == ""
          || request.resource.data.linkedUid in getAfter(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
        )
        && (
          !("preferredPaymentMethod" in request.resource.data)
          || isPaymentMethod(request.resource.data.preferredPaymentMethod)
        )
        && (
          !("paymentHandle" in request.resource.data)
          || isString(request.resource.data.paymentHandle, 160)
        )
        && (
          !("paymentLink" in request.resource.data)
          || isString(request.resource.data.paymentLink, 500)
        );
    }

    function isGroupMemberCreate(groupId, memberId) {
      return groupMemberAfter(groupId)
        && isMemberDoc(groupId, memberId)
        && (
          groupCreatorAfter(groupId)
          || request.resource.data.linkedUid == request.auth.uid
        );
    }

    function memberExists(groupId, memberId) {
      return memberId is string
        && memberId.size() > 0
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(memberId));
    }

    function linkedMemberIsActor(groupId, memberId) {
      return memberExists(groupId, memberId)
        && get(/databases/$(database)/documents/groups/$(groupId)/members/$(memberId)).data.linkedUid == request.auth.uid;
    }

    function canEditExistingGroupRow(groupId, payerMemberId) {
      return groupMember(groupId)
        && (
          (
            "createdByUid" in resource.data
            && resource.data.createdByUid == request.auth.uid
          )
          || linkedMemberIsActor(groupId, payerMemberId)
          || (
            !("createdByUid" in resource.data)
            && groupCreator(groupId)
          )
        );
    }

    function canDeleteExistingGroupRow(groupId, payerMemberId) {
      return canEditExistingGroupRow(groupId, payerMemberId);
    }

    function canEditExistingGroupPayment(groupId) {
      return canEditExistingGroupRow(groupId, resource.data.fromMemberId);
    }

    function canDeleteExistingGroupPayment(groupId) {
      return canEditExistingGroupPayment(groupId);
    }

    function canEditExistingSettlementRequest(groupId) {
      return groupMember(groupId)
        && (
          resource.data.requestedByUid == request.auth.uid
          || linkedMemberIsActor(groupId, resource.data.fromMemberId)
        );
    }

    function canDeleteExistingSettlementRequest(groupId) {
      return canEditExistingSettlementRequest(groupId);
    }

    function isExpenseDoc(groupId, expenseId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "description", "amount", "paidById", "splitType",
          "timestamp", "currency", "splits", "createdByUid", "category",
          "sourceType", "importBatchId", "transactionFingerprint",
          "parserMode", "parserConfidence", "notes", "sourceConfidence",
          "sourceWarnings", "createdAt", "updatedAt", "lastEditedByUid",
          "editCount", "originalAmount", "originalCurrency", "exchangeRate",
          "fxNote", "disputeStatus", "disputedByUid", "disputedAt",
          "disputeNote"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "description", "amount", "paidById", "splitType",
          "timestamp", "currency", "splits"
        ])
        && request.resource.data.id == expenseId
        && request.resource.data.groupId == groupId
        && isNonEmptyString(request.resource.data.description, 160)
        && isMoney(request.resource.data.amount)
        && memberExists(groupId, request.resource.data.paidById)
        && isSplitType(request.resource.data.splitType)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency)
        && isSmallStringMap(request.resource.data.splits)
        && (
          isCreatorFieldValid()
        )
        && (
          !("category" in request.resource.data)
          || isExpenseCategory(request.resource.data.category)
        )
        && hasValidExpenseImportProvenance()
        && hasValidExpenseMetadata()
        && hasValidExpenseFxMetadata()
        && hasValidExpenseDisputeMetadata();
    }

    function isPaymentDoc(groupId, paymentId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "fromMemberId", "toMemberId", "amount",
          "timestamp", "currency", "createdByUid", "updatedAt",
          "lastEditedByUid", "editCount"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "fromMemberId", "toMemberId", "amount",
          "timestamp", "currency"
        ])
        && request.resource.data.id == paymentId
        && request.resource.data.groupId == groupId
        && request.resource.data.fromMemberId != request.resource.data.toMemberId
        && memberExists(groupId, request.resource.data.fromMemberId)
        && memberExists(groupId, request.resource.data.toMemberId)
        && isMoney(request.resource.data.amount)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency)
        && (
          !("createdByUid" in request.resource.data)
          || isActorUid(request.resource.data.createdByUid)
          || (
            "createdByUid" in resource.data
            && request.resource.data.createdByUid == resource.data.createdByUid
          )
        )
        && (
          !("updatedAt" in request.resource.data)
          || isMillis(request.resource.data.updatedAt)
        )
        && (
          !("lastEditedByUid" in request.resource.data)
          || isActorUid(request.resource.data.lastEditedByUid)
        )
        && (
          !("editCount" in request.resource.data)
          || (
            request.resource.data.editCount is number
            && request.resource.data.editCount >= 0
            && request.resource.data.editCount <= 100000
          )
        );
    }

    function isSettlementRequestDoc(groupId, requestId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "fromMemberId", "toMemberId", "amount", "currency",
          "message", "status", "createdAt", "updatedAt", "requestedByUid",
          "lastRemindedAt", "remindAfter"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "fromMemberId", "toMemberId", "amount", "currency",
          "message", "status", "createdAt", "updatedAt", "requestedByUid"
        ])
        && request.resource.data.id == requestId
        && request.resource.data.groupId == groupId
        && request.resource.data.fromMemberId != request.resource.data.toMemberId
        && memberExists(groupId, request.resource.data.fromMemberId)
        && memberExists(groupId, request.resource.data.toMemberId)
        && isMoney(request.resource.data.amount)
        && isCurrency(request.resource.data.currency)
        && isString(request.resource.data.message, 500)
        && isSettlementRequestStatus(request.resource.data.status)
        && isMillis(request.resource.data.createdAt)
        && isMillis(request.resource.data.updatedAt)
        && (
          isActorUid(request.resource.data.requestedByUid)
          || (
            "requestedByUid" in resource.data
            && request.resource.data.requestedByUid == resource.data.requestedByUid
          )
        )
        && (
          !("lastRemindedAt" in request.resource.data)
          || isMillis(request.resource.data.lastRemindedAt)
        )
        && (
          !("remindAfter" in request.resource.data)
          || isMillis(request.resource.data.remindAfter)
        );
    }

    function isRecurringExpenseDoc(groupId, recurringId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "description", "amount", "paidById", "splitType",
          "currency", "splits", "category", "frequency", "nextDueAt",
          "active", "notes", "createdAt", "updatedAt", "createdByUid",
          "lastPostedAt", "originalAmount", "originalCurrency",
          "exchangeRate", "fxNote"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "description", "amount", "paidById", "splitType",
          "currency", "splits", "frequency", "nextDueAt", "active",
          "createdAt", "updatedAt", "createdByUid"
        ])
        && request.resource.data.id == recurringId
        && request.resource.data.groupId == groupId
        && isNonEmptyString(request.resource.data.description, 160)
        && isMoney(request.resource.data.amount)
        && memberExists(groupId, request.resource.data.paidById)
        && isSplitType(request.resource.data.splitType)
        && isCurrency(request.resource.data.currency)
        && isSmallStringMap(request.resource.data.splits)
        && (
          !("category" in request.resource.data)
          || isExpenseCategory(request.resource.data.category)
        )
        && isRecurringFrequency(request.resource.data.frequency)
        && isMillis(request.resource.data.nextDueAt)
        && request.resource.data.active is bool
        && (
          !("notes" in request.resource.data)
          || isString(request.resource.data.notes, 500)
        )
        && isMillis(request.resource.data.createdAt)
        && isMillis(request.resource.data.updatedAt)
        && (
          isActorUid(request.resource.data.createdByUid)
          || (
            "createdByUid" in resource.data
            && request.resource.data.createdByUid == resource.data.createdByUid
          )
        )
        && (
          !("lastPostedAt" in request.resource.data)
          || isMillis(request.resource.data.lastPostedAt)
        )
        && hasValidExpenseFxMetadata();
    }

    function isExpenseCommentDoc(groupId, commentId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "expenseId", "body", "createdAt",
          "createdByUid", "createdByName"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "expenseId", "body", "createdAt",
          "createdByUid", "createdByName"
        ])
        && request.resource.data.id == commentId
        && request.resource.data.groupId == groupId
        && exists(/databases/$(database)/documents/groups/$(groupId)/expenses/$(request.resource.data.expenseId))
        && isNonEmptyString(request.resource.data.body, 1000)
        && isMillis(request.resource.data.createdAt)
        && isActorUid(request.resource.data.createdByUid)
        && isNonEmptyString(request.resource.data.createdByName, 80);
    }

    function isFriendDoc(friendId) {
      return request.resource.data.keys().hasOnly([
          "id", "name", "email", "phone", "createdAt", "linkedUid", "createdByUid"
        ])
        && request.resource.data.keys().hasAll([
          "id", "name", "email", "phone", "createdAt", "linkedUid"
        ])
        && request.resource.data.id == friendId
        && isNonEmptyString(request.resource.data.name, 80)
        && isOptionalEmail(request.resource.data.email)
        && isString(request.resource.data.phone, 40)
        && isMillis(request.resource.data.createdAt)
        && isString(request.resource.data.linkedUid, 128)
        && (
          !("createdByUid" in request.resource.data)
          || isActorUid(request.resource.data.createdByUid)
        );
    }

    function selfOrFriend(uid, participantId) {
      return participantId == "self"
        || exists(/databases/$(database)/documents/users/$(uid)/friends/$(participantId));
    }

    function isAdHocExpenseDoc(uid, expenseId) {
      return request.resource.data.keys().hasOnly([
          "id", "description", "amount", "paidByFriendId", "splitType",
          "timestamp", "currency", "splits", "createdByUid", "category",
          "sourceType", "importBatchId", "transactionFingerprint",
          "parserMode", "parserConfidence", "mirroredFromPath",
          "mirroredFromUid", "originalId", "notes", "sourceConfidence",
          "sourceWarnings", "createdAt", "updatedAt", "lastEditedByUid",
          "editCount"
        ])
        && request.resource.data.keys().hasAll([
          "id", "description", "amount", "paidByFriendId", "splitType",
          "timestamp", "currency", "splits"
        ])
        && request.resource.data.id == expenseId
        && isNonEmptyString(request.resource.data.description, 160)
        && isMoney(request.resource.data.amount)
        && selfOrFriend(uid, request.resource.data.paidByFriendId)
        && isSplitType(request.resource.data.splitType)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency)
        && isSmallStringMap(request.resource.data.splits)
        && (
          isCreatorFieldValid()
        )
        && (
          !("category" in request.resource.data)
          || isExpenseCategory(request.resource.data.category)
        )
        && hasValidExpenseImportProvenance()
        && hasValidExpenseMetadata()
        && (
          !("mirroredFromPath" in request.resource.data)
          || isNonEmptyString(request.resource.data.mirroredFromPath, 500)
        )
        && (
          !("mirroredFromUid" in request.resource.data)
          || isNonEmptyString(request.resource.data.mirroredFromUid, 128)
        )
        && (
          !("originalId" in request.resource.data)
          || isNonEmptyString(request.resource.data.originalId, 160)
        );
    }

    function isSourceAdHocExpenseWrite() {
      return !("mirroredFromPath" in request.resource.data)
        && !("mirroredFromUid" in request.resource.data)
        && !("originalId" in request.resource.data);
    }

    function isAdHocMirrorMetadataUnchanged() {
      return "mirroredFromPath" in resource.data
        && request.resource.data.mirroredFromPath == resource.data.mirroredFromPath
        && request.resource.data.mirroredFromUid == resource.data.mirroredFromUid
        && request.resource.data.originalId == resource.data.originalId;
    }

    function canEditExistingAdHocExpense() {
      return (
          "createdByUid" in resource.data
          && resource.data.createdByUid == request.auth.uid
        )
        || resource.data.paidByFriendId == "self";
    }

    function canDeleteExistingAdHocExpense() {
      return !("mirroredFromPath" in resource.data)
        || resource.data.paidByFriendId == "self";
    }

    function canDeleteExistingAdHocPayment() {
      return !("mirroredFromPath" in resource.data)
        || resource.data.fromFriendId == "self";
    }

    function isAdHocPaymentDoc(uid, paymentId) {
      return request.resource.data.keys().hasOnly([
          "id", "fromFriendId", "toFriendId", "amount", "timestamp", "currency",
          "createdByUid", "mirroredFromPath", "mirroredFromUid", "originalId"
        ])
        && request.resource.data.keys().hasAll([
          "id", "fromFriendId", "toFriendId", "amount", "timestamp", "currency"
        ])
        && request.resource.data.id == paymentId
        && request.resource.data.fromFriendId != request.resource.data.toFriendId
        && selfOrFriend(uid, request.resource.data.fromFriendId)
        && selfOrFriend(uid, request.resource.data.toFriendId)
        && isMoney(request.resource.data.amount)
        && isMillis(request.resource.data.timestamp)
        && isCurrency(request.resource.data.currency)
        && (
          !("createdByUid" in request.resource.data)
          || isActorUid(request.resource.data.createdByUid)
        )
        && !("mirroredFromPath" in request.resource.data);
    }

    function isInviteDoc(inviteId) {
      return request.resource.data.keys().hasOnly([
          "id", "groupId", "groupName", "invitedByUid", "invitedByName", "invitedAt"
        ])
        && request.resource.data.keys().hasAll([
          "id", "groupId", "groupName", "invitedByUid", "invitedByName", "invitedAt"
        ])
        && request.resource.data.id == inviteId
        && request.resource.data.groupId == inviteId
        && request.resource.data.invitedByUid == request.auth.uid
        && isNonEmptyString(request.resource.data.groupName, 100)
        && isNonEmptyString(request.resource.data.invitedByName, 80)
        && isMillis(request.resource.data.invitedAt);
    }

    function isNotificationType(value) {
      return value in [
        "group_invite_received", "group_invite_accepted",
        "group_expense_created", "group_expense_deleted",
        "group_settlement_created", "group_settlement_deleted",
        "group_fully_settled", "friend_added",
        "adhoc_expense_created", "adhoc_expense_deleted",
        "adhoc_settlement_created", "adhoc_settlement_deleted"
      ];
    }

    function isNotificationDoc() {
      return request.resource.data.keys().hasOnly([
          "type", "title", "body", "actorUid", "targetUrl", "createdAt",
          "readAt", "eventId", "source"
        ])
        && request.resource.data.keys().hasAll([
          "type", "title", "body", "actorUid", "targetUrl", "createdAt",
          "readAt", "eventId", "source"
        ])
        && isNotificationType(request.resource.data.type)
        && isNonEmptyString(request.resource.data.title, 120)
        && isString(request.resource.data.body, 500)
        && isString(request.resource.data.actorUid, 128)
        && isNonEmptyString(request.resource.data.targetUrl, 500)
        && isMillis(request.resource.data.createdAt)
        && isNullableMillis(request.resource.data.readAt)
        && isNonEmptyString(request.resource.data.eventId, 500)
        && request.resource.data.source is map;
    }

    function isNotificationPreferenceDoc() {
      return request.resource.data.keys().hasOnly([
          "pushEnabled", "eventChannels", "largeExpenseThresholds", "updatedAt"
        ])
        && request.resource.data.pushEnabled is bool
        && request.resource.data.eventChannels is map
        && request.resource.data.eventChannels.keys().size() <= 50
        && request.resource.data.largeExpenseThresholds is map
        && request.resource.data.largeExpenseThresholds.keys().size() <= 20
        && isMillis(request.resource.data.updatedAt);
    }

    function isFcmTokenDoc() {
      return request.resource.data.keys().hasOnly([
          "token", "deviceLabel", "userAgent", "createdAt", "updatedAt",
          "lastSeenAt"
        ])
        && isNonEmptyString(request.resource.data.token, 4096)
        && isString(request.resource.data.deviceLabel, 120)
        && isString(request.resource.data.userAgent, 500)
        && isMillis(request.resource.data.createdAt)
        && isMillis(request.resource.data.updatedAt)
        && isMillis(request.resource.data.lastSeenAt);
    }

    // --- Users ---------------------------------------------------------------
    match /users/{uid} {
      // The app currently searches users by email for friend/group invite flows,
      // so reads remain signed-in. Writes are owner-only and schema-checked.
      allow get, list: if signedIn();
      allow create, update: if isOwner(uid) && isUserDoc(uid);
      allow delete: if false;

      match /friends/{friendId} {
        allow read: if isOwner(uid);
        allow create, update: if (
          isOwner(uid)
          || (
            signedIn()
            && request.auth.uid != uid
            && friendId == request.auth.uid
            && request.resource.data.linkedUid == request.auth.uid
          )
        ) && isFriendDoc(friendId);
        allow delete: if isOwner(uid);
      }

      match /adhocExpenses/{expenseId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isAdHocExpenseDoc(uid, expenseId)
          && isSourceAdHocExpenseWrite();
        allow update: if isOwner(uid)
          && isAdHocExpenseDoc(uid, expenseId)
          && canEditExistingAdHocExpense()
          && (
            (
              !("mirroredFromPath" in resource.data)
              && isSourceAdHocExpenseWrite()
            )
            || isAdHocMirrorMetadataUnchanged()
          );
        allow delete: if isOwner(uid) && canDeleteExistingAdHocExpense();
      }

      match /adhocPayments/{paymentId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isAdHocPaymentDoc(uid, paymentId);
        allow delete: if isOwner(uid) && canDeleteExistingAdHocPayment();
      }

      match /groupInvites/{inviteId} {
        allow read, delete: if isOwner(uid);
        allow create: if signedIn()
          && request.auth.uid != uid
          && isInviteDoc(inviteId)
          && groupMember(request.resource.data.groupId);
        allow update: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create: if false;
        allow update: if isOwner(uid)
          && isNotificationDoc()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"]);
        allow delete: if isOwner(uid);
      }

      match /notificationPreferences/{preferenceId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && preferenceId == "default"
          && isNotificationPreferenceDoc();
        allow delete: if false;
      }

      match /fcmTokens/{tokenId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isFcmTokenDoc();
        allow delete: if isOwner(uid);
      }
    }

    // --- Groups --------------------------------------------------------------
    match /groups/{groupId} {
      allow read: if groupMember(groupId);

      allow create: if signedIn()
        && isGroupDoc(groupId)
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      allow update: if isMetadataOnlyGroupUpdate(groupId)
        || isInviteAcceptance(groupId);

      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;

      match /members/{memberId} {
        allow read: if groupMember(groupId);
        allow create: if isGroupMemberCreate(groupId, memberId);
        allow update: if groupMember(groupId)
          && isMemberDoc(groupId, memberId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.groupId == resource.data.groupId
          && request.resource.data.name == resource.data.name
          && request.resource.data.email == resource.data.email
          && request.resource.data.linkedUid == resource.data.linkedUid
          && (
            groupCreator(groupId)
            || resource.data.linkedUid == request.auth.uid
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "preferredPaymentMethod", "paymentHandle", "paymentLink"
          ]);
        allow delete: if groupCreator(groupId);
      }

      match /expenses/{expenseId} {
        allow read: if groupMember(groupId);
        allow create: if groupMember(groupId)
          && isExpenseDoc(groupId, expenseId);
        allow update: if canEditExistingGroupRow(groupId, resource.data.paidById)
          && isExpenseDoc(groupId, expenseId);
        allow delete: if canDeleteExistingGroupRow(groupId, resource.data.paidById);
      }

      match /payments/{paymentId} {
        allow read: if groupMember(groupId);
        allow create: if groupMember(groupId)
          && isPaymentDoc(groupId, paymentId);
        allow update: if canEditExistingGroupPayment(groupId)
          && isPaymentDoc(groupId, paymentId);
        allow delete: if canDeleteExistingGroupPayment(groupId);
      }

      match /settlementRequests/{requestId} {
        allow read: if groupMember(groupId);
        allow create: if groupMember(groupId)
          && isSettlementRequestDoc(groupId, requestId);
        allow update: if canEditExistingSettlementRequest(groupId)
          && isSettlementRequestDoc(groupId, requestId);
        allow delete: if canDeleteExistingSettlementRequest(groupId);
      }

      match /recurringExpenses/{recurringId} {
        allow read: if groupMember(groupId);
        allow create: if groupMember(groupId)
          && isRecurringExpenseDoc(groupId, recurringId);
        allow update: if canEditExistingGroupRow(groupId, resource.data.paidById)
          && isRecurringExpenseDoc(groupId, recurringId);
        allow delete: if canDeleteExistingGroupRow(groupId, resource.data.paidById);
      }

      match /expenseComments/{commentId} {
        allow read: if groupMember(groupId);
        allow create: if groupMember(groupId)
          && isExpenseCommentDoc(groupId, commentId);
        allow update: if false;
        allow delete: if groupMember(groupId)
          && resource.data.createdByUid == request.auth.uid;
      }
    }
  }
}
