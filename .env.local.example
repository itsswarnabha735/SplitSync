# SplitSync Web — Firebase configuration
#
# Copy this file to `.env.local` and fill in the values from your Firebase
# project: Firebase Console -> Project Settings -> "Your apps" -> Web app ->
# "SDK setup and configuration" -> Config.
#
# The current repo shipped with a PLACEHOLDER project (splitsync-placeholder).
# You must register a real Firebase Web app and enable the Email/Password and
# Google sign-in providers (Authentication -> Sign-in method) for auth to work.

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-web-push-vapid-key

# Server-only. Used by /api/parse-statement; never expose this as NEXT_PUBLIC_*.
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Set to "true" to point the app at local Firebase emulators (see firebase.json).
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
